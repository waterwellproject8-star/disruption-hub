# ════════════════════════════════════════════════════════════════
# DisruptionHub — Environment Variables
# Copy this file to .env.local for local development
# Add all of these to Vercel → Settings → Environment Variables
# ════════════════════════════════════════════════════════════════

# ── REQUIRED — nothing works without this ────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── REQUIRED — your live domain ──────────────────────────────────
NEXT_PUBLIC_APP_URL=https://disruptionhub.ai

# ── REQUIRED — make up any random string ─────────────────────────
CRON_SECRET=make-up-any-secure-string-here

# ── OPTIONAL — add later when you have paying clients ────────────
# Supabase (free tier — add when you have clients)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio (for automated SMS and calls — add when needed)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+441234567890

# Resend (for email — free tier covers early clients)
RESEND_API_KEY=re_your-key-here
FROM_EMAIL=hello@disruptionhub.ai

# Web Push / Driver PWA (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key

# Companies House API (free — improves subcontractor checks)
COMPANIES_HOUSE_API_KEY=your-api-key
